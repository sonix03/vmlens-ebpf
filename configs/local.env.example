# Local operator configuration for VMLens.
#
# Copy this file to:
#
#   configs/local.env
#
# The copied file is ignored by git so each laptop can keep its own SSH key path
# and local VM inventory.

# Default SSH user for VMs. Can be overridden per VM profile below.
VMLENS_SSH_USER=ubuntu

# Default SSH key.
#
# Common values:
#   ~/.ssh/id_ed25519_vmlens
#   /mnt/c/Users/<WINDOWS_USER>/.ssh/id_ed25519_vmlens
#   agent
#   none
#
# Use "agent" or "none" when you want SSH to use ~/.ssh/config, ssh-agent,
# or another default authentication method without forcing "-i <key>".
VMLENS_SSH_KEY=~/.ssh/id_ed25519_vmlens

# Local API that runs on the laptop/PC.
VMLENS_LOCAL_BACKEND=127.0.0.1:8080

# Backend endpoint created inside each VM by the reverse SSH tunnel.
VMLENS_REMOTE_BACKEND=127.0.0.1:18080

# VM profiles. Put every tracked VM profile here.
#
# Profile names must be shell-safe identifiers: letters, numbers and underscore.
# Each profile can define:
#
#   VMLENS_VM_<PROFILE>_ALIAS
#   VMLENS_VM_<PROFILE>_HOST
#   VMLENS_VM_<PROFILE>_SSH_USER
#   VMLENS_VM_<PROFILE>_SSH_KEY
#   VMLENS_VM_<PROFILE>_REMOTE_BACKEND
#   VMLENS_VM_<PROFILE>_LOCAL_BACKEND
#
# Use "-" or omit a field to inherit the default above.
VMLENS_VM_PROFILES="testing_a_1 testing_a_2 testing_a_3 testing_a_4"

VMLENS_VM_TESTING_A_1_ALIAS=testing-a-1
VMLENS_VM_TESTING_A_1_HOST=10.20.20.130
VMLENS_VM_TESTING_A_1_SSH_USER=-
VMLENS_VM_TESTING_A_1_SSH_KEY=-

VMLENS_VM_TESTING_A_2_ALIAS=testing-a-2
VMLENS_VM_TESTING_A_2_HOST=10.20.20.199
VMLENS_VM_TESTING_A_2_SSH_USER=-
VMLENS_VM_TESTING_A_2_SSH_KEY=-

VMLENS_VM_TESTING_A_3_ALIAS=testing-a-3
VMLENS_VM_TESTING_A_3_HOST=10.20.20.188
VMLENS_VM_TESTING_A_3_SSH_USER=-
VMLENS_VM_TESTING_A_3_SSH_KEY=-

# Example fourth VM with its own key.
VMLENS_VM_TESTING_A_4_ALIAS=testing-a-4
VMLENS_VM_TESTING_A_4_HOST=10.20.20.210
VMLENS_VM_TESTING_A_4_SSH_USER=ubuntu
VMLENS_VM_TESTING_A_4_SSH_KEY=~/.ssh/id_ed25519_vmlens_testing_a_4

# Optional legacy inventory file. Only used when VMLENS_VM_PROFILES is empty.
VMLENS_VM_INVENTORY=configs/vms.local

# Local state paths for SSH control sockets and copied Windows keys.
VMLENS_TUNNEL_STATE_DIR=~/.vmlens/tunnels
VMLENS_KEY_STATE_DIR=~/.vmlens/keys
