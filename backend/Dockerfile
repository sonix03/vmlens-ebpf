FROM golang:1.22-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/vmlens-api ./cmd/api

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/vmlens-api /vmlens-api
EXPOSE 8080
ENTRYPOINT ["/vmlens-api"]

